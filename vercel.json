{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "admin-panel-frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "admin-panel-frontend/dist"
      }
    },
    {
      "src": "api/vercel.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/vercel.js"
    },
    {
      "src": "/admin/(.*)",
      "dest": "/admin-panel-frontend/dist/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/$1"
    }
  ]
}