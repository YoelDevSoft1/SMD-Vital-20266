{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/servicios/lavado-de-oidos-a-domicilio",
      "destination": "/lavado-de-oidos-a-domicilio",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/_astro/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
