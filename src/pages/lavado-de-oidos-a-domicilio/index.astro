      { variant: 'primary', target: '_blank', text: 'Lavado de Oídos Barato WhatsApp', href: 'https://wa.me/573042912564' },
      { variant: 'secondary', text: 'Agenda Limpieza de Oídos', href: 'tel:3042912564' },
    ]}
    image={{
      src: 'https://images.pexels.com/photos/5206945/pexels-photo-5206945.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1',
      alt: 'Profesional médico realizando limpieza auditiva a domicilio con equipos especializados - SMD Vital Bogotá',
      loading: 'eager',
      width: 1260,
      height: 750,
    }}
  >
    <Fragment slot="title">
      <div class="leading-[0.9]">
        <h1 class="text-4xl md:text-6xl font-bold text-gray-900 dark:text-white mb-4">
          Lavado de Oídos en Bogotá a Domicilio
        </h1>
        <div class="text-2xl md:text-3xl text-accent dark:text-white highlight font-semibold">
          Servicio Profesional y Económico
