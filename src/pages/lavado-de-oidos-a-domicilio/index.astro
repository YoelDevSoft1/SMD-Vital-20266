---
import Layout from '~/layouts/PageLayout.astro';

import Header from '~/components/widgets/Header.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Features from '~/components/widgets/Features.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import Breadcrumbs from '~/components/ui/Breadcrumbs.astro';

import { headerData } from '~/navigation';
import { SITE } from 'astrowind:config';

// Schema.org para FAQs (Expandido con 10 preguntas)
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '¿Qué es el lavado de oídos?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Es un procedimiento para remcer y otros residuos del canal auditivo, mejorando la audición y previniendo molestias.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Es doloroso el procedimiento?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No, el lavado de oídos, si se realiza correctamente, es indoloro y seguro. Nuestro personal se asegura de minimizar cualquier molestia.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Cuánto cuesta el lavado de oídos a domicilio en Bogotá?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'El precio del lavado de oídos a domicilio en Bogotá es de $140,000 COP. Este valor incluye evaluación inicial, procedimiento completo, materiales estériles y cuidados posteriores. Sin costos ocultos, precios transparentes.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Qué diferencia hay entre lavado de oídos e irrigación?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'La irrigación es una técnica dentro del lavado de oídos que utiliza agua tibia a presión controlada. Nuestros profesionales evalúan cada caso y determinan si es necesaria irrigación, aspiración o una combinación de técnicas para remover el cerumen de forma segura.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Puedo hacerme el lavado de oídos yo mismo en casa?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No se recomienda hacerlo sin supervisión profesional. El uso incorrecto de hisopos, pinzas u otros objetos puede empujar el cerumen más profundo o dañar el tímpano. Nuestro servicio profesional garantiza seguridad y efectividad.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Con qué frecuencia debo realizar un lavado de oídos?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Depende de cada persona. Si presentas acumulación frecuente de cerumen, nuestro equipo puede aconsejarte sobre la periodicidad adecuada, generalmente entre 3 a 6 meses.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Qué contraindicaciones tiene el lavado de oídos?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No se recomienda en casos de perforación timpánica, infección activa del oído, cirugía reciente del oído o sangrado. Nuestro personal realiza una evaluación previa para determinar si el procedimiento es seguro para ti.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Pueden atender a niños y adultos mayores?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sí, adaptamos el procedimiento según la edad y condición del paciente, brindando una experiencia segura para todos. Tenemos experiencia trabajando con pacientes pediátricos y geriátricos.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Cada cuánto tiempo debo hacerme limpieza de oídos?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'La frecuencia varía según la producción individual de cerumen. Algunos pacientes necesitan limpieza cada 3-4 meses, mientras que otros pueden esperar 6-12 meses. Después de la primera evaluación, te daremos una recomendación personalizada.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Cómo agendo el lavado de oídos a domicilio?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Puedes hacerlo fácilmente a través de WhatsApp al +57 304 291 2564, llamando a nuestro call center o completando el formulario en nuestro sitio web. Atendemos 24/7 en todas las localidades de Bogotá.',
      },
    },
  ],
};

