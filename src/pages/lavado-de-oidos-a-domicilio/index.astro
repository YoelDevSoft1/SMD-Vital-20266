const metadata = {
  title: 'Lavado de Oídos a Domicilio en Bogotá | Profesional y Económico | SMD Vital',
  description:
    'Lavado de oídos en Bogotá a domicilio. Servicio médico profesional con precios desde $140.000 COP. Médicos a domicilio especializados en limpieza de oídos. Atención 24/7 en toda la capital.',
  keywords: 'lavado de oídos, lavados de oídos, lavado de oidos en bogota, lavado de oido bogota, lavado de oídos precio, médico a domicilio, médicos a domicilio, medico a domicilio bogota, servicio médico a domicilio, atención médica a domicilio, limpieza de oidos bogota, lavado de oídos bogotá',
  ignoreTitleTemplate: true,
