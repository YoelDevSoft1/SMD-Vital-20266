  '@context': 'https://schema.org',
  '@type': 'Review',
  itemReviewed: {
    '@type': 'MedicalBusiness',
    name: 'SMD Vital - Valoración Médica Domiciliaria Bogotá'
  },
  author: {
    '@type': 'Person',
    name: 'Carlos Rodríguez'
  },
  reviewRating: {
    '@type': 'Rating',
    ratingValue: 5,
    bestRating: '5'
