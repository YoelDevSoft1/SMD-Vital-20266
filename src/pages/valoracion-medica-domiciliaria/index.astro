  ignoreTitleTemplate: true,
  openGraph: {
    title: 'Valoración Médica Domiciliaria | Médico a Domicilio Barato | SMD Vital Bogotá',
    description: 'Valoración médica a domicilio barato en Bogotá. Médicos certificados para evaluación médica completa, diagnóstico y tratamiento. Servicio 24/7 en toda Bogotá. Precio $120.000 COP.',
