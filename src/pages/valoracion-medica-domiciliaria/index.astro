const metadata = {
  title: 'Valoración Médica Domiciliaria en Bogotá | Médico a Domicilio Barato | SMD Vital',
  description: 'Valoración médica a domicilio barato en Bogotá. Médicos certificados para evaluación médica completa, diagnóstico y tratamiento. Servicio 24/7 en las 20 localidades. Precio $120.000 COP.',
