    id="procedimiento"
    title="¿Cómo Funciona Nuestra Valoración Médica?"
    subtitle="Proceso profesional paso a paso realizado por médicos certificados con equipos especializados"
    isReversed
    items={[
      {
        title: '1. Revisión de Antecedentes',
        description:
          'Entrevista médica detallada para conocer síntomas, antecedentes médicos y medicamentos actuales del paciente.',
        icon: 'tabler:clipboard',
      },
      {
        title: '2. Examen Físico Completo',
        description: `Evaluación sistemática incluyendo signos vitales, auscultación, palpación y evaluación de sistemas corporales.`,
        icon: 'tabler:stethoscope',
      },
      {
        title: '3. Diagnóstico y Evaluación',
        description: `Análisis de hallazgos para establecer diagnóstico clínico y determinar necesidades de tratamiento específico.`,
        icon: 'tabler:microscope',
      },
      {
        title: '4. Recomendaciones y Seguimiento',
        description: `Entrega de recomendaciones de tratamiento, prescripciones médicas y plan de seguimiento personalizado.`,
        icon: 'tabler:checklist',
      },
    ]}
