    images: [
      {
        url: 'https://images.pexels.com/photos/40568/medical-appointment-doctor-healthcare-40568.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1',
        width: 1260,
        height: 750,
        alt: 'Servicio profesional de valoración médica domiciliaria en Bogotá - SMD Vital',
      },
    ],
  },
  twitter: {
    card: 'summary_large_image',
    site: '@SMDVitalBogota',
    creator: '@SMDVitalBogota',
    title: 'Valoración Médica Domiciliaria | Médico a Domicilio Barato | SMD Vital',
