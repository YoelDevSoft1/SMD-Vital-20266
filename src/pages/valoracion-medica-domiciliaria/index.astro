        description: 'Evaluación médica detallada con análisis clínico profesional para un diagnóstico preciso y confiable.',
        icon: 'tabler:microscope',
      },
      {
        title: 'Cobertura Total',
        description: 'Servicio disponible en las 20 localidades de Bogotá y municipios cercanos. Atención 24/7 todos los días.',
        icon: 'tabler:map-pin',
      },
    ]}
