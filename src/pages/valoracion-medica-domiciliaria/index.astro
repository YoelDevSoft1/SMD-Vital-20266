    columns={3}
    items={[
      {
        title: 'Médicos Certificados',
        description: 'Profesionales médicos certificados con amplia experiencia en evaluación médica integral y diagnóstico clínico.',
        icon: 'tabler:stethoscope',
      },
      {
        title: 'Equipos Especializados',
        description: 'Utilizamos equipos médicos portátiles profesionales para examen físico completo y diagnóstico preciso.',
        icon: 'tabler:medical-cross',
      },
