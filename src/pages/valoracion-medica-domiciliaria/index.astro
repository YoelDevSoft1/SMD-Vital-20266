  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '¿Qué es la valoración médica domiciliaria?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Es un servicio médico integral que incluye examen físico completo, revisión de antecedentes, diagnóstico profesional y recomendaciones de tratamiento en la comodidad de tu hogar.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Cuánto cuesta la valoración médica a domicilio?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'El precio de la valoración médica a domicilio en Bogotá es de $120,000 COP. Este valor incluye evaluación completa, diagnóstico, recomendaciones y prescripciones médicas si es necesario.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Qué incluye la valoración médica domiciliaria?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Incluye examen físico completo, revisión de antecedentes médicos, diagnóstico profesional, recomendaciones de tratamiento, prescripciones médicas si es necesario y seguimiento posterior.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Cuánto tiempo dura la valoración médica?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'La valoración médica domiciliaria dura entre 45-60 minutos, dependiendo de la complejidad del caso. Incluye tiempo para examen físico, diagnóstico y explicación detallada del tratamiento.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Pueden atender cualquier tipo de enfermedad?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Atendemos la mayoría de condiciones médicas generales. Para casos complejos o especializados, realizamos la valoración inicial y referimos al especialista correspondiente si es necesario.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Puedo solicitar valoración médica sin tener síntomas?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sí, la valoración médica también es útil para chequeos preventivos, control periódico de salud y seguimiento de condiciones crónicas. Es una excelente forma de mantener tu salud bajo control.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Qué equipos médicos utilizan?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Utilizamos equipos médicos portátiles profesionales incluyendo estetoscopio, tensiómetro, termómetro, otoscopio, oftalmoscopio y equipos básicos de diagnóstico para brindar una evaluación completa.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Pueden atender a niños y adultos mayores?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sí, atendemos pacientes de todas las edades. Adaptamos la valoración según las necesidades específicas de cada grupo etario, brindando atención especializada para niños y adultos mayores.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Qué diferencia hay entre valoración médica y consulta médica?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'La valoración médica es más integral e incluye examen físico completo, revisión de antecedentes y diagnóstico detallado. Una consulta médica puede ser más específica para un síntoma particular.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Cómo agendo una valoración médica domiciliaria?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Puedes agendar fácilmente a través de WhatsApp al +57 304 291 2564, llamando a nuestro call center o completando el formulario en nuestro sitio web. Atendemos 24/7 en todas las localidades de Bogotá.',
      },
    },
  ],
};

