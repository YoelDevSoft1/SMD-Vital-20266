<Layout metadata={metadata}>
  <!-- Schema.org JSON-LD -->
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(howToSchema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(reviewSchema)}></script>
  </Fragment>

  <Fragment slot="header">
    <Header
      {...headerData}
      actions={[
        {
          variant: 'secondary',
          text: 'Llamar Ahora',
          href: 'tel:3042912564',
        },
        {
          variant: 'primary',
          text: 'WhatsApp',
          href: 'https://wa.me/573042912564',
          icon: 'tabler:brand-whatsapp',
        },
      ]}
      isSticky
    />
  </Fragment>

  <!-- Hero2 Widget ******************* -->

  <section class="relative -mt-[76px]">
    <!-- Breadcrumbs integrados -->
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 pt-24">
      <Breadcrumbs
        items={[
          { label: 'Servicios', href: '/servicios' },
          { label: 'Valoración Médica Domiciliaria' },
        ]}
      />
    </div>
  </section>

  <Hero2
    tagline="Evaluación Médica Profesional"
    actions={[
      { variant: 'primary', target: '_blank', text: 'Valoración Médica WhatsApp', href: 'https://wa.me/573042912564' },
      { variant: 'secondary', text: 'Agendar Evaluación Médica', href: 'tel:3042912564' },
    ]}
    image={{
      src: 'https://images.pexels.com/photos/40568/medical-appointment-doctor-healthcare-40568.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1',
      alt: 'Médico profesional realizando valoración médica a domicilio con equipos especializados - SMD Vital Bogotá',
      loading: 'eager',
      width: 1260,
      height: 750,
    }}
  >
    <Fragment slot="title">
      Valoración Médica Domiciliaria<br />
      <span class="text-accent dark:text-white highlight">Bogotá Barato</span><br />
      Médico a Domicilio Profesional
