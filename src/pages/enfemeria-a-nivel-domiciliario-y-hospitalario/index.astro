    {
      '@type': 'HowToSupply', 
      name: 'Materiales estériles',
      description: 'Guantes, gasas, jeringas y otros materiales de un solo uso'
    },
    {
      '@type': 'HowToSupply',
      name: 'Medicamentos prescritos',
      description: 'Medicamentos según prescripción médica del paciente'
    },
    {
      '@type': 'HowToSupply',
      name: 'Equipos de monitoreo',
      description: 'Termómetros, tensiómetros y otros equipos de monitoreo'
    }
  ],
  tool: [
    {
      '@type': 'HowToTool',
      name: 'Equipos de monitoreo',
      description: 'Instrumentos para toma de signos vitales y monitoreo continuo'
