const metadata = {
  title: 'Enfermería a Domicilio en Bogotá | Profesional y Económico | SMD Vital',
  description:
    'Enfermería a domicilio en Bogotá. Servicio médico profesional con precios desde $80.000 COP por hora. Enfermeras a domicilio especializadas en cuidados especializados. Atención 24/7 en toda la capital.',
  keywords: 'enfermería a domicilio, enfermera a domicilio, enfermería bogotá, enfermera bogotá, enfermería precio, médico a domicilio, médicos a domicilio, medico a domicilio bogota, servicio médico a domicilio, atención médica a domicilio, cuidados domiciliarios bogota, enfermería a domicilio bogotá',
  ignoreTitleTemplate: true,
  openGraph: {
    siteName: 'SMD Vital Bogotá',
    type: 'website',
    images: [
      {
        url: 'https://images.pexels.com/photos/3279197/pexels-photo-3279197.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1',
        width: 1260,
        height: 750,
      },
    ],
  },
  twitter: {
    handle: '@SMDVitalBogota',
    site: '@SMDVitalBogota',
    cardType: 'summary_large_image',
  },
};

