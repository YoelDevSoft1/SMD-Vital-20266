---

<Layout metadata={metadata}>
  <!-- Schema.org JSON-LD -->
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(howToSchema)}></script>
  </Fragment>

  <Fragment slot="header">
    <Header
      {...headerData}
      actions={[
        {
          variant: 'secondary',
          text: 'Llamar Ahora',
          href: 'tel:3042912564',
        },
        {
          variant: 'primary',
          text: 'WhatsApp',
          href: 'https://wa.me/573042912564',
          icon: 'tabler:brand-whatsapp',
        },
      ]}
      isSticky
    />
  </Fragment>

  <!-- Hero2 Widget ******************* -->

  <section class="relative -mt-[76px]">
    <!-- Breadcrumbs integrados -->
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 pt-24">
      <Breadcrumbs
        items={[
          { label: 'Servicios', href: '/servicios' },
          { label: 'Enfermería a Domicilio' },
        ]}
      />
    </div>
  </section>

  <Hero2
    tagline="Cuidado Experto para tu Salud"
    actions={[
      { variant: 'primary', target: '_blank', text: 'Enfermería Barato WhatsApp', href: 'https://wa.me/573042912564' },
      { variant: 'secondary', text: 'Agenda Cuidados', href: 'tel:3042912564' },
    ]}
    image={{
      src: 'https://images.pexels.com/photos/3279197/pexels-photo-3279197.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1',
      alt: 'Profesional de enfermería realizando cuidados especializados a domicilio con equipos médicos - SMD Vital Bogotá',
      loading: 'eager',
      width: 1260,
      height: 750,
    }}
  >
    <Fragment slot="title">
      <div class="leading-[0.9]">
        <h1 class="text-4xl md:text-6xl font-bold text-gray-900 dark:text-white mb-4">
          Enfermería a Domicilio en Bogotá
        </h1>
        <div class="text-2xl md:text-3xl text-accent dark:text-white highlight font-semibold">
          Servicio Profesional y Económico
        </div>
        <div class="text-xl md:text-2xl text-gray-700 dark:text-gray-300 mt-2">
          Cuidados Especializados
        </div>
      </div>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="font-semibold text-lg">Enfermería a domicilio profesional en Bogotá</span> con cuidados especializados, administración de medicamentos y curaciones profesionales para aliviar molestias y mejorar tu bienestar sin salir de casa.
      <br /><br />
      Nuestro equipo certificado te ofrece un servicio confiable y económico en las 20 localidades de la capital. Precios transparentes sin costos ocultos.
    </Fragment>
  </Hero2>

  <!-- Features Widget *************** -->

  <Features
    id="beneficios"
    tagline="Servicio Profesional"
    title="¿Por qué elegir nuestra enfermería a domicilio en Bogotá?"
    subtitle="Ofrecemos atención de enfermería profesional en tu hogar con técnicas seguras y especializadas para aliviar molestias y mejorar tu bienestar. Nuestro equipo certificado te brinda un servicio confiable y económico en las 20 localidades de la capital."
    columns={3}
    items={[
      {
        title: 'Sin Dolor ni Molestias',
        description:
          'Procedimientos completamente cómodos con técnicas profesionales certificadas. Alivio inmediato y mejora en el bienestar del paciente.',
        icon: 'tabler:heart-handshake',
      },
      {
        title: 'Equipos Especializados',
        description: `Utilizamos instrumental médico profesional certificado para cuidados especializados, administración de medicamentos y curaciones de forma segura.`,
        icon: 'tabler:medical-cross',
      },
      {
        title: 'Atención en 45 Minutos',
        description: 'Respuesta rápida en toda la ciudad. Agenda tu cita y recibe atención profesional el mismo día sin largas esperas.',
        icon: 'tabler:clock',
      },
      {
        title: 'Personal Certificado',
        description: `Enfermeras especializadas con certificación en cuidados especializados y amplia experiencia en atención domiciliaria.`,
        icon: 'tabler:certificate',
      },
      {
        title: 'Resultados Inmediatos',
        description: 'Mejora instantánea del bienestar y cuidados especializados garantizados en cada visita.',
        icon: 'tabler:check',
      },
      {
        title: 'Cobertura Total',
        description: `Servicio disponible en las 20 localidades de la capital y municipios cercanos. Atención 24/7 todos los días.`,
        icon: 'tabler:map-pin',
      },
    ]}
  />

  <!-- Content Widget - Procedimiento **************** -->

  <Content
    id="procedimiento"
    title="¿Cómo Funciona Nuestro Procedimiento?"
    subtitle="Proceso profesional paso a paso realizado por especialistas certificados"
    isReversed
    items={[
      {
        title: '1. Evaluación Inicial del Paciente',
        description:
          'Evaluación completa del paciente, revisión de historia clínica y determinación de necesidades específicas de cuidado.',
        icon: 'tabler:clipboard-check',
      },
      {
        title: '2. Desarrollo del Plan de Cuidados',
        description: `Creación de un plan de cuidados personalizado según las necesidades del paciente y prescripción médica.`,
        icon: 'tabler:file-text',
      },
      {
        title: '3. Implementación de Cuidados',
        description: `Aplicación de cuidados especializados, administración de medicamentos y monitoreo continuo del paciente.`,
        icon: 'tabler:medical-cross',
      },
      {
        title: '4. Seguimiento y Educación',
        description: `Monitoreo de evolución, educación al paciente y familia, y coordinación con el equipo médico tratante.`,
        icon: 'tabler:school',
      },
    ]}
    image={{
      src: 'https://images.pexels.com/photos/6129193/pexels-photo-6129193.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1',
      alt: 'Procedimiento paso a paso de enfermería a domicilio con equipos médicos especializados',
      loading: 'lazy',
      width: 1260,
      height: 750,
    }}
  >
    <Fragment slot="content">
      <h2 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Procedimiento Certificado
      </h2>
      <p class="text-muted mt-4">
        Utilizamos técnicas aprobadas por la Organización Mundial de la Salud (OMS) y el Ministerio de Salud de Colombia para garantizar tu seguridad y bienestar.
      </p>
    </Fragment>
  </Content>

  <!-- Content Widget - Cuándo necesitas **************** -->

  <Content
    id="cuando-necesitas"
    isAfterContent={true}
    items={[
      {
        title: 'Indicaciones para Enfermería a Domicilio',
        description: `✓ Cuidados post-operatorios y recuperación<br>
                      ✓ Enfermedades crónicas (diabetes, hipertensión)<br>
                      ✓ Cuidados paliativos y terminales<br>
                      ✓ Administración de medicamentos complejos<br>
                      ✓ Monitoreo de signos vitales continuo`,
        icon: 'tabler:stethoscope',
      },
      {
        title: '¿Quiénes lo Necesitan?',
        description: `✓ Pacientes post-operatorios en recuperación<br>
                      ✓ Adultos mayores con dependencia<br>
                      ✓ Pacientes con enfermedades crónicas<br>
                      ✓ Personas con movilidad reducida<br>
                      ✓ Familias que necesitan apoyo especializado`,
        icon: 'tabler:users',
      },
    ]}
    image={{
      src: 'https://images.pexels.com/photos/6097980/pexels-photo-6097980.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1',
      alt: 'Paciente con necesidades de enfermería a domicilio consultando sobre cuidados especializados',
      loading: 'lazy',
      width: 1260,
      height: 750,
