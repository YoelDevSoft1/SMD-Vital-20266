---
import Layout from '~/layouts/PageLayout.astro';

import Header from '~/components/widgets/Header.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Features from '~/components/widgets/Features.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import Breadcrumbs from '~/components/ui/Breadcrumbs.astro';

import { headerData } from '~/navigation';
import { SITE } from 'astrowind:config';

// Schema.org para FAQs (Expandido con 10 preguntas)
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '¿Qué es la enfermería a domicilio?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Es un servicio de atención de enfermería profesional que se brinda en el hogar del paciente, incluyendo cuidados especializados, administración de medicamentos, curaciones y monitoreo de signos vitales.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Es doloroso el servicio de enfermería?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No, nuestros servicios de enfermería están diseñados para ser cómodos y seguros. Las enfermeras utilizan técnicas suaves y profesionales para minimizar cualquier molestia durante los procedimientos.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Cuánto cuesta la enfermería a domicilio en Bogotá?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'El precio de la enfermería a domicilio en Bogotá es de $80,000 COP por hora. Este valor incluye evaluación inicial, cuidados especializados, materiales estériles y seguimiento posterior. Sin costos ocultos, precios transparentes.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Qué diferencia hay entre enfermería a domicilio y hospitalaria?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'La enfermería a domicilio se brinda en el hogar del paciente, ofreciendo mayor comodidad y personalización. La hospitalaria se realiza en centros médicos con equipos especializados pero menos intimidad familiar.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Puedo contratar enfermería sin prescripción médica?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Para algunos servicios como administración de medicamentos inyectables sí se requiere prescripción médica. Para cuidados básicos y monitoreo, podemos evaluar las necesidades del paciente.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Con qué frecuencia necesito servicios de enfermería?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Depende de las necesidades específicas del paciente. Algunos requieren atención diaria, otros cada 2-3 días. Después de la evaluación inicial, te daremos una recomendación personalizada.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Qué contraindicaciones tiene la enfermería a domicilio?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No se recomienda en casos de emergencias médicas graves que requieran atención hospitalaria inmediata. Nuestro personal realiza una evaluación previa para determinar si el servicio es seguro para ti.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Pueden atender a niños y adultos mayores?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sí, adaptamos el servicio según la edad y condición del paciente, brindando una experiencia segura para todos. Tenemos experiencia trabajando con pacientes pediátricos y geriátricos.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Cada cuánto tiempo necesito enfermería especializada?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'La frecuencia varía según las necesidades específicas del paciente. Algunos requieren atención diaria, otros cada 2-3 días. Después de la primera evaluación, te daremos una recomendación personalizada.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Cómo agendo la enfermería a domicilio?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Puedes hacerlo fácilmente a través de WhatsApp al +57 304 291 2564, llamando a nuestro call center o completando el formulario en nuestro sitio web. Atendemos 24/7 en todas las localidades de Bogotá.',
      },
    },
  ],
};

