  image: {
    '@type': 'ImageObject',
    url: 'https://images.pexels.com/photos/6129193/pexels-photo-6129193.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1',
    caption: 'Procedimiento profesional de enfermería a domicilio con equipos médicos especializados'
  },
  totalTime: 'PT60M',
  estimatedCost: {
    '@type': 'MonetaryAmount',
    currency: 'COP',
    value: '80000'
  },
  supply: [
    {
      '@type': 'HowToSupply',
      name: 'Equipos médicos especializados',
      description: 'Instrumental médico profesional para cuidados especializados'
