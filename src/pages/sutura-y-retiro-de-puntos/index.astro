      alt: 'Instrumentos quirúrgicos para sutura y retiro de puntos a domicilio - Servicio médico especializado SMD Vital',
      loading: 'eager',
      width: 1260,
      height: 750,
    }}
  >
    <Fragment slot="title">
      Sutura y Retiro de Puntos<br />
      <span class="text-accent dark:text-white highlight">Bogotá Barato</span><br />
