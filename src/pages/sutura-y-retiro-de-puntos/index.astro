    columns={3}
    items={[
      {
        title: 'Suturas Quirúrgicas Profesionales',
        description: 'Técnicas asépticas certificadas con materiales estériles de un solo uso. Suturas simples, continuas y retiro seguro de puntos de cirugía.',
        icon: 'tabler:medical-cross',
      },
      {
        title: 'Personal Certificado en Cirugía',
        description: 'Enfermeros especializados con certificación en técnicas quirúrgicas y amplia experiencia en suturas y cuidado de heridas.',
        icon: 'tabler:certificate',
