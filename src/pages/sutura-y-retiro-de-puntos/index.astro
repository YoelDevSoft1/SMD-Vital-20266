<Layout metadata={metadata}>
  <!-- Schema.org JSON-LD -->
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(howToSchema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(reviewSchema)}></script>
  </Fragment>

  <Fragment slot="header">
    <Header
      {...headerData}
      actions={[
        {
          variant: 'secondary',
          text: 'Llamar Ahora',
          href: 'tel:3042912564',
        },
        {
          variant: 'primary',
          text: 'WhatsApp',
          href: 'https://wa.me/573042912564',
          icon: 'tabler:brand-whatsapp',
        },
      ]}
      isSticky
    />
  </Fragment>

  <!-- Breadcrumbs con Schema.org -->
  <div class="container mx-auto px-4 pt-20 md:pt-24">
    <Breadcrumbs
      items={[
        { label: 'Servicios', href: '/servicios' },
        { label: 'Sutura y Retiro de Puntos' },
      ]}
    />
  </div>

  <!-- Hero2 Widget ******************* -->
