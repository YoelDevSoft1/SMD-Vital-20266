---
import Layout from '~/layouts/PageLayout.astro';

import Header from '~/components/widgets/Header.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Features from '~/components/widgets/Features.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import Breadcrumbs from '~/components/ui/Breadcrumbs.astro';

import { headerData } from '~/navigation';
import { SITE } from 'astrowind:config';

// Schema.org para FAQs (Expandido con 10 preguntas)
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '¿Qué es la sutura y retiro de puntos a domicilio?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Es un servicio médico especializado que consiste en la aplicación de suturas para cerrar heridas y el retiro posterior de puntos quirúrgicos en la comodidad de tu hogar, realizado por profesionales certificados.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Cuánto cuesta la sutura y retiro de puntos a domicilio en Bogotá?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'El precio de la sutura y retiro de puntos a domicilio en Bogotá es de $120.000 COP. Este valor incluye evaluación inicial, procedimiento completo, materiales estériles y cuidados posteriores. Sin costos ocultos, precios transparentes.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Qué tipos de suturas pueden realizar a domicilio?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Realizamos suturas simples, suturas continuas, suturas de grapas quirúrgicas y retiro de puntos de cirugía. Nuestros profesionales evalúan cada caso y determinan la técnica más adecuada según el tipo de herida.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Es seguro realizar suturas a domicilio?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sí, contamos con profesionales certificados en técnicas quirúrgicas y seguimos estrictos protocolos de higiene y seguridad. Utilizamos materiales estériles de un solo uso y técnicas asépticas certificadas.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Cuándo debo retirar los puntos de sutura?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'El tiempo de retiro varía según la ubicación y tipo de herida. Generalmente entre 7-14 días para heridas faciales y 10-21 días para heridas corporales. Nuestros profesionales evalúan cada caso individualmente.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Qué diferencia hay entre sutura simple y continua?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'La sutura simple utiliza puntos individuales, ideal para heridas pequeñas. La sutura continua utiliza un hilo continuo, ideal para heridas largas. Nuestros profesionales determinan la técnica más adecuada según el caso.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Pueden realizar suturas a niños y adultos mayores?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sí, tenemos experiencia realizando suturas a pacientes de todas las edades. Adaptamos las técnicas según la edad y condición del paciente para minimizar molestias y garantizar la mejor cicatrización.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Qué debo tener listo para la sutura a domicilio?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Solo necesitas tener el área limpia y estar cómodo. Nosotros llevamos todo el equipo necesario: hilos de sutura, agujas, instrumental quirúrgico, materiales estériles y anestesia local si es necesaria.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Los servicios están cubiertos por EPS o medicina prepagada?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Algunos servicios pueden tener cobertura parcial. Te ayudamos con la gestión de autorizaciones y emitimos facturas para reembolsos ante pólizas de salud.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Cómo agendo la sutura y retiro de puntos a domicilio?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Puedes agendar por WhatsApp al +57 304 291 2564, llamando a nuestro call center o completando el formulario en nuestro sitio web. Atendemos 24/7 en toda Bogotá.',
      },
    },
  ],
};

