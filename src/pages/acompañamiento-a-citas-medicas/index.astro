    columns={3}
    items={[
      {
        title: 'Asistencia Personalizada Completa',
        description:
          'Acompañamiento a consultas médicas ajustado a tus necesidades específicas, brindando apoyo logístico y emocional en cada etapa de tu cita médica.',
        icon: 'tabler:layers-union',
      },
      {
        title: 'Comunicación Eficaz con Médicos',
        description: `Facilitamos la interacción con el personal médico, asegurando que comprendas claramente los procedimientos y recomendaciones durante tu cita.`,
        icon: 'tabler:artboard',
      },
      {
        title: 'Acompañamiento para Personas Mayores',
        description:
          'Especialmente diseñado para personas mayores, brindando asistencia adicional, apoyo en movilidad y tranquilidad durante todo el proceso médico.',
        icon: 'tabler:writing',
      },
      {
        title: 'Acompañamiento Pediátrico',
        description: `Servicio especializado para niños que reduce la ansiedad durante consultas y procedimientos médicos, brindando tranquilidad a los padres.`,
