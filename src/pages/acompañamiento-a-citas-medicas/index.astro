---
import Layout from '~/layouts/PageLayout.astro';

import Header from '~/components/widgets/Header.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Features from '~/components/widgets/Features.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Content from '~/components/widgets/Content.astro';
import Breadcrumbs from '~/components/ui/Breadcrumbs.astro';

import { headerData } from '~/navigation';
import { SITE } from 'astrowind:config';
import FAQs from '~/components/widgets/FAQs.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';

// Schema.org para FAQs
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '¿Qué es el acompañamiento a citas médicas a domicilio?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Es un servicio especializado que consiste en brindar asistencia personalizada, apoyo logístico y emocional durante consultas médicas, exámenes y procedimientos, garantizando una experiencia segura y tranquila en la comodidad de tu hogar.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Cuánto cuesta el acompañamiento a citas médicas en Bogotá?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'El precio del acompañamiento a citas médicas a domicilio en Bogotá es de $120.000 COP. Este valor incluye asistencia personalizada, coordinación con el personal médico, apoyo logístico y seguimiento completo. Sin costos ocultos, precios transparentes.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Qué tipos de citas médicas pueden acompañar?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Acompañamos consultas generales, citas de especialidad, exámenes médicos, procedimientos ambulatorios, tratamientos especializados y consultas pediátricas. Nuestro equipo se adapta a cualquier tipo de cita médica.',
      },
    },
    {
      '@type': 'Question',
      name: '¿El servicio es adecuado para personas mayores?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sí, nuestro acompañamiento está especialmente diseñado para personas mayores, brindando apoyo adicional, asistencia en movilidad y tranquilidad durante todo el proceso médico.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Ofrecen acompañamiento pediátrico?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sí, contamos con acompañamiento pediátrico especializado que reduce la ansiedad de los niños durante consultas y procedimientos médicos, brindando tranquilidad a los padres.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Cómo agendo el acompañamiento a citas médicas?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Puedes agendar por WhatsApp al +57 304 291 2564, llamando a nuestro call center o completando el formulario en nuestro sitio web. Atendemos 24/7 en toda Bogotá.',
      },
    },
  ],
};

// Schema para el servicio específico
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'MedicalBusiness',
  name: 'SMD Vital - Acompañamiento a Citas Médicas a Domicilio Bogotá',
  alternateName: 'SMD Vital Bogotá - Acompañante Médico Barato',
  description: 'Acompañamiento a citas médicas a domicilio barato en Bogotá. Acompañante médico, asistencia médica a domicilio, acompañamiento para personas mayores. Servicio 24/7 en las 20 localidades. Precio $120.000 COP.',
  url: SITE.site + '/acompañamiento-a-citas-medicas/',
  telephone: '+57-304-291-2564',
  email: 'salud@smdvitalbogota.com',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Servicio a Domicilio',
    addressLocality: 'Bogotá',
    addressRegion: 'Cundinamarca',
    postalCode: '110111',
    addressCountry: 'CO'
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: '4.7110',
    longitude: '-74.0721'
  },
  areaServed: [
    {
      '@type': 'City',
      name: 'Bogotá',
      sameAs: 'https://es.wikipedia.org/wiki/Bogot%C3%A1'
    }
  ],
  medicalSpecialty: [
    'Nursing',
    'PrimaryCare',
    'PatientCare',
    'Geriatrics',
    'Pediatrics'
  ],
  keywords: 'acompañamiento a citas médicas, acompañamiento médico a domicilio, acompañante médico bogotá, acompañamiento a consultas médicas, asistencia médica a domicilio, acompañamiento para personas mayores, acompañamiento pediátrico',
  priceRange: '$$',
  openingHours: ['Mo-Su 00:00-23:59'],
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.9',
    reviewCount: '85',
    bestRating: '5',
    worstRating: '1'
  },
  sameAs: [
    'https://www.facebook.com/profile.php?id=61556817451561',
    'https://www.instagram.com/smdvitalbogota_/',
    'https://x.com/smdvitalbogotaoficial'
  ],
  currenciesAccepted: 'COP',
  paymentAccepted: 'Efectivo, Transferencia Bancaria, Tarjeta',
  availableLanguage: ['es']
};

// Schema Reviews
const reviewSchema = {
  '@context': 'https://schema.org',
  '@type': 'Review',
  itemReviewed: {
    '@type': 'MedicalBusiness',
    name: 'SMD Vital - Acompañamiento a Citas Médicas a Domicilio Bogotá'
  },
  author: {
    '@type': 'Person',
    name: 'María Elena Rodríguez'
  },
  reviewRating: {
    '@type': 'Rating',
    ratingValue: '5',
    bestRating: '5'
  },
  reviewBody: 'Excelente servicio de acompañamiento a citas médicas. El personal fue muy profesional y me ayudó mucho durante mi consulta. Muy recomendado para personas mayores.'
};

const metadata = {
  title: 'Acompañamiento a Citas Médicas a Domicilio en Bogotá | Profesional y Económico | SMD Vital',
  description:
    'Acompañamiento a citas médicas a domicilio barato en Bogotá. Acompañante médico, asistencia médica a domicilio, acompañamiento para personas mayores. Servicio 24/7 en las 20 localidades. Precio $120.000 COP.',
  keywords: 'acompañamiento a citas médicas, acompañamiento médico a domicilio, acompañante médico bogotá, acompañamiento a consultas médicas, asistencia médica a domicilio, acompañamiento para personas mayores, acompañamiento pediátrico, acompañamiento a exámenes médicos',
  ignoreTitleTemplate: true,
  openGraph: {
    title: 'Acompañamiento a Citas Médicas a Domicilio Bogotá | $120.000 COP | SMD Vital',
    description: 'Acompañamiento profesional a citas médicas a domicilio barato en Bogotá. Asistencia personalizada, apoyo logístico. Servicio 24/7 en toda Bogotá. Precio $120.000 COP.',
    type: 'website',
    images: [
      {
        url: 'https://images.pexels.com/photos/8460157/pexels-photo-8460157.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1',
        width: 1260,
        height: 750,
        alt: 'Acompañamiento a citas médicas a domicilio en Bogotá - SMD Vital',
      },
    ],
  },
  twitter: {
    card: 'summary_large_image',
    site: '@SMDVitalBogota',
    creator: '@SMDVitalBogota',
    title: 'Acompañamiento a Citas Médicas a Domicilio Bogotá | SMD Vital',
    description: 'Acompañamiento profesional a citas médicas en tu hogar. Servicio especializado 24/7 en toda Bogotá.',
  },
};
---

<Layout metadata={metadata}>
  <!-- Schema.org JSON-LD -->
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(reviewSchema)}></script>
  </Fragment>

  <Fragment slot="header">
    <Header
      {...headerData}
      actions={[
        {
          variant: 'secondary',
          text: 'Llamar Ahora',
          href: 'tel:3042912564',
        },
        {
          variant: 'primary',
          text: 'WhatsApp',
          href: 'https://wa.me/573042912564',
          icon: 'tabler:brand-whatsapp',
        },
      ]}
