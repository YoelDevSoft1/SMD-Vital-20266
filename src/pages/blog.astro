---
import type { InferGetStaticPropsType, GetStaticPaths } from 'astro';

import Layout from '~/layouts/PageLayout.astro';
import List from '~/components/blog/List.astro';
import Pagination from '~/components/blog/Pagination.astro';
import { getCanonical, getPermalink } from '~/utils/permalinks';
import type { MetaData } from '~/types';
import { getStaticPathsBlogList, fetchPosts } from '~/utils/blog';

export const prerender = true;

export const getStaticPaths = getStaticPathsBlogList;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { posts, pagination } = Astro.props as Props;

// Convertir los posts a la estructura correcta
const normalizedPosts = await fetchPosts();

const url = getCanonical(getPermalink('blog'));

const metadata: MetaData = {
  title: 'Blog - SMD Vital Bogotá',
  description: 'Artículos y guías sobre salud domiciliaria, cuidados médicos y servicios de atención a domicilio en Bogotá. Consejos de expertos en medicina domiciliaria.',
  canonical: String(url),
  openGraph: {
    type: 'website',
    url: String(url),
    siteName: 'SMD Vital Bogotá',
  },
};
---

<Layout metadata={metadata}>
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <!-- Header del blog -->
    <div class="text-center mb-16">
      <h1 class="text-4xl font-bold text-gray-900 dark:text-white sm:text-5xl md:text-6xl">
        Blog SMD Vital
      </h1>
      <p class="mt-4 text-xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto">
        Guías, consejos y artículos especializados sobre salud domiciliaria, cuidados médicos y servicios de atención a domicilio en Bogotá.
      </p>
    </div>

    <!-- Lista de artículos -->
    <List posts={normalizedPosts} />
    
    <!-- Paginación -->
    {pagination && <Pagination {...pagination} />}
  </div>
</Layout>
