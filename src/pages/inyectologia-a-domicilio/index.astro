    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget - Precios **************** -->

  <Content
    id="precios"
    title="Precios de Inyectología a Domicilio"
    subtitle="Servicio médico especializado a domicilio con precios justos y transparentes. Sin sorpresas, sin costos adicionales."
    isReversed
    items={[
      {
        title: 'Precio Fijo Garantizado',
        description: `$100.000 COP - Precio único para todas las localidades de la ciudad. Sin costos ocultos, sin sorpresas.`,
        icon: 'tabler:currency-peso',
      },
