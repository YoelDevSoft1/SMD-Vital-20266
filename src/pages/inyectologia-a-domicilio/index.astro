const metadata = {
  title: 'Inyectología a Domicilio en Bogotá | Profesional y Económico | SMD Vital',
  description:
    'Inyectología a domicilio en Bogotá. Servicio médico profesional con precios desde $100.000 COP. Aplicación de medicamentos, vitaminas e inmunizaciones a domicilio. Atención 24/7 en toda la capital.',
  keywords: 'inyectología a domicilio, inyectologia a domicilio, servicio de inyectología a domicilio, servicio inyectologia a domicilio, servicio de inyectologia cerca de mi, servicio de inyectología, inyecciones a domicilio, aplicación medicamentos domicilio, vitaminas intramusculares',
  ignoreTitleTemplate: true,
  openGraph: {
    siteName: 'SMD Vital Bogotá',
    type: 'website',
    images: [
      {
        url: 'https://images.pexels.com/photos/4386431/pexels-photo-4386431.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1',
        width: 1260,
        height: 750,
      },
    ],
  },
  twitter: {
    handle: '@SMDVitalBogota',
    site: '@SMDVitalBogota',
    cardType: 'summary_large_image',
  },
};

// Schema HowTo para el procedimiento de inyectología
