---

<Layout metadata={metadata}>
  <!-- Schema.org JSON-LD -->
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(howToSchema)}></script>
  </Fragment>

  <Fragment slot="header">
    <Header
      {...headerData}
      actions={[
        {
          variant: 'secondary',
          text: 'Llamar Ahora',
          href: 'tel:3042912564',
        },
        {
          variant: 'primary',
          text: 'WhatsApp',
          href: 'https://wa.me/573042912564',
          icon: 'tabler:brand-whatsapp',
        },
      ]}
      isSticky
    />
  </Fragment>

  <!-- Hero2 Widget ******************* -->

  <section class="relative -mt-[76px]">
    <!-- Breadcrumbs integrados -->
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 pt-24">
      <Breadcrumbs
        items={[
          { label: 'Servicios', href: '/servicios' },
          { label: 'Inyectología a Domicilio' },
        ]}
      />
    </div>
  </section>

  <Hero2
    tagline="Cuidado Experto para tu Salud"
    actions={[
      { variant: 'primary', target: '_blank', text: 'Inyectología Barato WhatsApp', href: 'https://wa.me/573042912564' },
      { variant: 'secondary', text: 'Agenda Inyecciones', href: 'tel:3042912564' },
    ]}
    image={{
      src: 'https://st5.depositphotos.com/2714617/77701/i/600/depositphotos_777011958-stock-photo-young-friendly-nurse-doctor-help.jpg',
      alt: 'Enfermera joven y amigable realizando inyectología a domicilio en Bogotá - SMD Vital',
      loading: 'eager',
      width: 1260,
      height: 750,
    }}
  >
    <Fragment slot="title">
      <div class="leading-[0.9]">
        <h1 class="text-4xl md:text-6xl font-bold text-gray-900 dark:text-white mb-4">
          Inyectología a Domicilio en Bogotá
        </h1>
        <div class="text-2xl md:text-3xl text-accent dark:text-white highlight font-semibold">
          Servicio Profesional y Económico
        </div>
        <div class="text-xl md:text-2xl text-gray-700 dark:text-gray-300 mt-2">
          Aplicación de Medicamentos
        </div>
      </div>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="font-semibold text-lg">Inyectología a domicilio profesional en Bogotá</span> con aplicación de medicamentos, vitaminas e inmunizaciones para mejorar tu salud y bienestar sin salir de casa.
      <br /><br />
      Nuestro equipo certificado te ofrece un servicio confiable y económico en las 20 localidades de la capital. Precios transparentes sin costos ocultos.
    </Fragment>
  </Hero2>

  <!-- Features Widget *************** -->

  <Features
    id="beneficios"
    tagline="Servicio Profesional"
    title="¿Por qué elegir nuestra inyectología a domicilio en Bogotá?"
    subtitle="Ofrecemos aplicación de medicamentos profesional en tu hogar con técnicas seguras y especializadas para mejorar tu salud y bienestar. Nuestro equipo certificado te brinda un servicio confiable y económico en las 20 localidades de la capital."
    columns={3}
    items={[
      {
        title: 'Sin Dolor ni Molestias',
        description:
          'Procedimientos prácticamente indoloros con técnicas profesionales certificadas. Aplicación suave y cómoda para tu bienestar.',
        icon: 'tabler:heart-handshake',
      },
      {
        title: 'Equipos Especializados',
        description: `Utilizamos instrumental médico profesional certificado para inyecciones intramusculares, subcutáneas e intravenosas de forma segura.`,
        icon: 'tabler:medical-cross',
      },
      {
        title: 'Atención en 45 Minutos',
        description: 'Respuesta rápida en toda la ciudad. Agenda tu cita y recibe atención profesional el mismo día sin largas esperas.',
        icon: 'tabler:clock',
      },
      {
        title: 'Personal Certificado',
        description: `Profesionales especializados con certificación en inyectología y amplia experiencia en aplicación de medicamentos.`,
        icon: 'tabler:certificate',
      },
      {
        title: 'Resultados Inmediatos',
        description: 'Aplicación efectiva de medicamentos y vitaminas con resultados inmediatos en tu bienestar.',
        icon: 'tabler:check',
      },
      {
        title: 'Cobertura Total',
        description: `Servicio disponible en las 20 localidades de la capital y municipios cercanos. Atención 24/7 todos los días.`,
        icon: 'tabler:map-pin',
      },
