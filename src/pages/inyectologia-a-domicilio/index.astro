---
import Layout from '~/layouts/PageLayout.astro';

import Header from '~/components/widgets/Header.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Features from '~/components/widgets/Features.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import Breadcrumbs from '~/components/ui/Breadcrumbs.astro';

import { headerData } from '~/navigation';
import { SITE } from 'astrowind:config';

// Schema.org para FAQs (Expandido con 10 preguntas)
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '¿Qué es la inyectología a domicilio?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Es un servicio médico especializado que consiste en la aplicación de medicamentos, vitaminas y tratamientos terapéuticos mediante inyecciones intramusculares, subcutáneas o intravenosas en la comodidad de tu hogar.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Es doloroso el procedimiento?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No, la inyectología a domicilio, si se realiza correctamente, es prácticamente indolora y segura. Nuestro personal se asegura de minimizar cualquier molestia utilizando técnicas profesionales.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Cuánto cuesta la inyectología a domicilio en Bogotá?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'El precio de la inyectología a domicilio en Bogotá es de $100,000 COP. Este valor incluye evaluación inicial, aplicación profesional, materiales estériles y seguimiento posterior. Sin costos ocultos, precios transparentes.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Qué diferencia hay entre inyectología a domicilio y en clínica?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'La inyectología a domicilio se realiza en tu hogar, ofreciendo mayor comodidad y privacidad. La clínica requiere desplazamiento pero tiene equipos especializados. Nuestro servicio combina ambas ventajas.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Puedo recibir inyecciones sin prescripción médica?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Para medicamentos prescritos sí se requiere prescripción médica. Para vitaminas y sueros multivitamínicos podemos evaluar las necesidades del paciente y aplicar según protocolos médicos.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Con qué frecuencia puedo recibir inyecciones?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Depende del tipo de tratamiento y prescripción médica. Algunos requieren aplicación diaria, otros semanal o mensual. Después de la evaluación inicial, te daremos una recomendación personalizada.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Qué contraindicaciones tiene la inyectología?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No se recomienda en casos de alergias conocidas a los medicamentos, infecciones activas en el sitio de inyección, o condiciones médicas específicas. Nuestro personal realiza una evaluación previa.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Pueden atender a niños y adultos mayores?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sí, adaptamos el procedimiento según la edad y condición del paciente, brindando una experiencia segura para todos. Tenemos experiencia trabajando con pacientes pediátricos y geriátricos.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Cada cuánto tiempo necesito inyectología?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'La frecuencia varía según el tipo de tratamiento y necesidades específicas. Algunos requieren aplicación diaria, otros semanal. Después de la primera evaluación, te daremos una recomendación personalizada.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Cómo agendo la inyectología a domicilio?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Puedes hacerlo fácilmente a través de WhatsApp al +57 304 291 2564, llamando a nuestro call center o completando el formulario en nuestro sitio web. Atendemos 24/7 en todas las localidades de Bogotá.',
      },
    },
  ],
};

