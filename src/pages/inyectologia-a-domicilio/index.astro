  image: {
    '@type': 'ImageObject',
    url: 'https://images.pexels.com/photos/4386431/pexels-photo-4386431.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1',
    caption: 'Procedimiento profesional de inyectología a domicilio con equipos médicos especializados'
  },
  totalTime: 'PT30M',
  estimatedCost: {
    '@type': 'MonetaryAmount',
    currency: 'COP',
    value: '100000'
  },
  supply: [
    {
      '@type': 'HowToSupply',
      name: 'Medicamentos prescritos',
