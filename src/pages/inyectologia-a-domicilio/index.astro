    id="procedimiento"
    title="¿Cómo Funciona Nuestro Procedimiento?"
    subtitle="Proceso profesional paso a paso realizado por especialistas certificados"
    isReversed
    items={[
      {
        title: '1. Evaluación Inicial del Paciente',
        description:
          'Evaluación médica completa, revisión de historia clínica y verificación de contraindicaciones para el tratamiento.',
        icon: 'tabler:clipboard-check',
      },
      {
        title: '2. Preparación del Material',
        description: `Preparación de medicamentos, materiales estériles y verificación de dosis correctas según prescripción médica.`,
        icon: 'tabler:medical-cross',
      },
      {
        title: '3. Aplicación Profesional',
        description: `Aplicación de la inyección utilizando técnicas asépticas y sitios anatómicos apropiados para máxima efectividad.`,
        icon: 'tabler:medical-cross',
      },
      {
        title: '4. Seguimiento y Cuidados',
        description: `Monitoreo post-inyección, educación al paciente y disposición segura de desechos médicos.`,
        icon: 'tabler:shield-check',
      },
    ]}
    image={{
      src: 'https://st5.depositphotos.com/8214686/78467/i/600/depositphotos_784677852-stock-photo-nursing-sick-senior-man-intravenous.jpg',
      alt: 'Enfermera aplicando inyección intravenosa a adulto mayor - Procedimiento profesional de inyectología a domicilio - SMD Vital',
      loading: 'lazy',
      width: 1260,
      height: 750,
    }}
  >
    <Fragment slot="content">
      <h2 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Procedimiento Certificado
      </h2>
      <p class="text-muted mt-4">
        Utilizamos técnicas aprobadas por la Organización Mundial de la Salud (OMS) y el Ministerio de Salud de Colombia para garantizar tu seguridad y bienestar.
      </p>
    </Fragment>
  </Content>

  <!-- Content Widget - Cuándo necesitas **************** -->

  <Content
    id="cuando-necesitas"
    isAfterContent={true}
    items={[
      {
        title: 'Indicaciones para Inyectología a Domicilio',
        description: `✓ Aplicación de medicamentos prescritos<br>
                      ✓ Vitaminas intramusculares y sueros<br>
                      ✓ Inmunizaciones y vacunas<br>
                      ✓ Tratamientos para el dolor<br>
                      ✓ Sueros multivitamínicos`,
        icon: 'tabler:medical-cross',
      },
      {
        title: '¿Quiénes lo Necesitan?',
        description: `✓ Pacientes con medicamentos inyectables<br>
                      ✓ Personas que requieren vitaminas<br>
                      ✓ Tratamientos de inmunización<br>
                      ✓ Terapias de dolor crónico<br>
                      ✓ Suplementación nutricional`,
        icon: 'tabler:users',
      },
    ]}
    image={{
      src: 'https://st5.depositphotos.com/2714617/77701/i/600/depositphotos_777011980-stock-photo-young-smiling-nurse-doctor-help.jpg',
