const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '¿Qué es la electrocardiografía básica a domicilio?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Es un servicio médico especializado que consiste en la realización de electrocardiogramas (ECG) básicos en la comodidad de tu hogar, utilizando equipos portátiles profesionales para evaluar la función cardíaca.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Cuánto cuesta la electrocardiografía básica a domicilio en Bogotá?',
      acceptedAnswer: {
        '@type': 'Answer',
