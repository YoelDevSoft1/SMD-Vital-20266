  medicalSpecialty: [
    'PrimaryCare',
    'InternalMedicine',
    'Pediatrics',
    'Psychology',
    'Telemedicine'
  ],
  keywords: 'telemedicina, teleconsulta, teleconsulta médica, consulta médica online, videoconsulta, médico virtual, telemedicina online, atención médica online, médico a domicilio virtual, consulta médica virtual, telemedicina bogotá, médico virtual bogotá',
  priceRange: '$$',
  openingHours: ['Mo-Su 00:00-23:59'],
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: [
        'Monday',
        'Tuesday',
        'Wednesday',
        'Thursday',
        'Friday',
        'Saturday',
        'Sunday'
      ],
      opens: '00:00',
      closes: '23:59'
    }
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Servicios de Telemedicina y Teleconsulta',
    itemListElement: [
      {
    '@type': 'Offer',
        itemOffered: {
          '@type': 'MedicalProcedure',
          name: 'Telemedicina y Teleconsulta Online',
          description: 'Consulta médica virtual por videollamada con diagnóstico y recomendaciones de tratamiento'
        },
        price: '80000',
    priceCurrency: 'COP',
        availability: 'https://schema.org/InStock',
        validFrom: '2024-01-01',
        priceValidUntil: '2024-12-31',
        includesObject: [
          'Consulta virtual por videollamada',
          'Diagnóstico médico profesional',
          'Recomendaciones de tratamiento',
          'Prescripciones médicas digitales',
          'Seguimiento posterior'
        ]
      }
    ]
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.8',
    reviewCount: '150',
    bestRating: '5',
    worstRating: '1'
  },
  sameAs: [
    'https://www.facebook.com/profile.php?id=61556817451561',
    'https://www.instagram.com/smdvitalbogota_/',
    'https://x.com/smdvitalbogotaoficial'
  ],
  currenciesAccepted: 'COP',
  paymentAccepted: 'Efectivo, Transferencia Bancaria, Tarjeta',
  availableLanguage: ['es']
};

// Schema Reviews para testimonios
const reviewSchema = {
  '@context': 'https://schema.org',
  '@type': 'Review',
  itemReviewed: {
    '@type': 'MedicalBusiness',
    name: 'SMD Vital - Telemedicina y Teleconsulta Bogotá'
  },
  author: {
    '@type': 'Person',
    name: 'Ana Martínez'
  },
  reviewRating: {
    '@type': 'Rating',
    ratingValue: '5',
    bestRating: '5'
  },
  reviewBody: 'Excelente servicio de teleconsulta médica. El médico fue muy profesional, me explicó todo claramente y recibí mis fórmulas médicas al instante. Muy recomendado para evitar desplazamientos.'
};

// Schema HowTo para el procedimiento de teleconsulta
const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'Cómo realizar telemedicina y teleconsulta médica profesional',
  description: 'Procedimiento paso a paso para realizar consulta médica virtual y telemedicina de forma profesional y segura',
  image: {
    '@type': 'ImageObject',
    url: 'https://images.pexels.com/photos/4225920/pexels-photo-4225920.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1',
    caption: 'Procedimiento profesional de telemedicina y teleconsulta médica por videollamada segura'
  },
  totalTime: 'PT30M',
  estimatedCost: {
    '@type': 'MonetaryAmount',
    currency: 'COP',
    value: '80000'
  },
  supply: [
    {
      '@type': 'HowToSupply',
      name: 'Dispositivo con cámara',
      description: 'Celular, tablet o computador con cámara y micrófono funcionales'
    },
    {
      '@type': 'HowToSupply',
      name: 'Conexión a internet',
      description: 'Conexión estable a internet para videollamada de calidad'
    },
    {
      '@type': 'HowToSupply',
      name: 'Lugar tranquilo',
      description: 'Espacio privado y tranquilo para la consulta médica'
    }
  ],
  tool: [
    {
      '@type': 'HowToTool',
      name: 'Plataforma de videollamada',
      description: 'Sistema seguro de videollamada con encriptación de datos'
    },
    {
      '@type': 'HowToTool',
      name: 'Sistema de registro médico',
      description: 'Plataforma para documentación y prescripciones médicas'
    }
  ],
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: 'Contacto y Triage',
      text: 'Contactar por WhatsApp o call center, registrar síntomas y antecedentes para asignar al profesional médico adecuado.',
      image: {
        '@type': 'ImageObject',
        url: 'https://images.pexels.com/photos/4225920/pexels-photo-4225920.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1',
        caption: 'Proceso de contacto y triage inicial para telemedicina y teleconsulta médica'
      },
      url: SITE.site + '/teleconsulta-medica/#procedimiento'
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: 'Videollamada Segura',
      text: 'Recibir enlace de conexión y participar en videollamada HD con el médico especialista desde cualquier dispositivo.',
      image: {
        '@type': 'ImageObject',
        url: 'https://images.pexels.com/photos/4225920/pexels-photo-4225920.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1',
        caption: 'Videollamada segura para telemedicina y consulta médica virtual profesional'
      },
      url: SITE.site + '/teleconsulta-medica/#procedimiento'
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: 'Diagnóstico y Tratamiento',
      text: 'Durante la sesión se resuelven dudas, se define medicamentos y plan terapéutico personalizado con documentación completa.',
      image: {
        '@type': 'ImageObject',
        url: 'https://images.pexels.com/photos/4225920/pexels-photo-4225920.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1',
        caption: 'Proceso de diagnóstico y definición de tratamiento durante telemedicina y teleconsulta'
      },
      url: SITE.site + '/teleconsulta-medica/#procedimiento'
    },
    {
      '@type': 'HowToStep',
      position: 4,
      name: 'Seguimiento y Control',
      text: 'Entrega de fórmulas médicas digitales, seguimiento posterior y coordinación de visitas presenciales si es necesario.',
      image: {
        '@type': 'ImageObject',
        url: 'https://images.pexels.com/photos/4225920/pexels-photo-4225920.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1',
        caption: 'Seguimiento posterior y entrega de documentación médica digital en telemedicina'
      },
      url: SITE.site + '/teleconsulta-medica/#procedimiento'
    }
  ],
  author: {
    '@type': 'Organization',
    name: 'SMD Vital Bogotá',
    url: SITE.site,
    telephone: '+57-304-291-2564',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Bogotá',
      addressCountry: 'CO'
    }
  },
  publisher: {
    '@type': 'Organization',
    name: 'SMD Vital Bogotá',
    url: SITE.site,
    logo: {
      '@type': 'ImageObject',
      url: SITE.site + '/images/logo.png'
    }
