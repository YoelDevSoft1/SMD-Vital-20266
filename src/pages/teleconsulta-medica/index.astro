---
import Layout from '~/layouts/PageLayout.astro';

import Header from '~/components/widgets/Header.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import Breadcrumbs from '~/components/ui/Breadcrumbs.astro';

import { headerData } from '~/navigation';
import { SITE } from 'astrowind:config';

// Schema.org para FAQs (Expandido con 10 preguntas)
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '¿Qué es la teleconsulta médica?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Es un servicio de consulta médica virtual que permite recibir atención médica profesional a través de videollamada segura, sin necesidad de desplazarse a una clínica o consultorio.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Cuánto cuesta la teleconsulta médica?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'El precio de la teleconsulta médica en Bogotá es de $80,000 COP. Este valor incluye consulta virtual, diagnóstico, recomendaciones de tratamiento y prescripciones médicas digitales.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Qué necesito para recibir la teleconsulta?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Solo necesitas un dispositivo con cámara y micrófono (celular, tablet o computador), conexión estable a internet y un lugar tranquilo. Nuestro equipo te envía el enlace y te acompaña durante el proceso.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Puedo recibir fórmulas médicas por teleconsulta?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sí, al finalizar la teleconsulta recibirás las fórmulas médicas, incapacidades, órdenes de laboratorio o recomendaciones digitales, con validez legal en Colombia.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Cuándo se recomienda pasar a una visita presencial?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Si el médico identifica signos de alarma o requiere examen físico detallado, coordinamos una visita a domicilio o te orientamos hacia el centro de urgencias más cercano.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Cuál es el tiempo de respuesta para teleconsulta?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Respondemos en menos de 5 minutos por WhatsApp o call center. Envías tus datos básicos y en minutos recibirás la confirmación y el enlace de conexión.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Qué especialidades médicas están disponibles?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Contamos con medicina general, pediatría, medicina interna, psicología y especialistas aliados. Todos registrados ante el Ministerio de Salud de Colombia.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Es segura la teleconsulta médica?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sí, utilizamos plataformas seguras con encriptación de datos y cumplimos con todas las normativas de protección de información médica en Colombia.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Puedo hacer teleconsulta para control de enfermedades crónicas?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sí, la teleconsulta es ideal para control de hipertensión, diabetes, EPOC y salud mental. Evaluamos signos vitales que reportas y ajustamos tratamientos sin salir de casa.',
      },
    },
    {
    '@type': 'Question',
      name: '¿Cómo agendo una teleconsulta médica?',
    acceptedAnswer: {
      '@type': 'Answer',
        text: 'Puedes agendar fácilmente a través de WhatsApp al +57 304 291 2564, llamando a nuestro call center o completando el formulario en nuestro sitio web. Atendemos 24/7 en todas las localidades de Bogotá.',
      },
    },
  ],
};

// Schema para el servicio específico (LocalBusiness mejorado)
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'MedicalBusiness',
  name: 'SMD Vital - Telemedicina y Teleconsulta Bogotá',
  alternateName: 'SMD Vital Bogotá - Consulta Médica Online',
  description: 'Telemedicina y teleconsulta médica online en Bogotá. Consulta médica virtual por videollamada con médicos certificados. Atención médica online 24/7 en las 20 localidades.',
  url: SITE.site + '/teleconsulta-medica/',
  telephone: '+57-304-291-2564',
  email: 'salud@smdvitalbogota.com',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Servicio a Domicilio',
    addressLocality: 'Bogotá',
    addressRegion: 'Cundinamarca',
    postalCode: '110111',
    addressCountry: 'CO'
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: '4.7110',
    longitude: '-74.0721'
  },
  areaServed: [
    {
    '@type': 'City',
    name: 'Bogotá',
      sameAs: 'https://es.wikipedia.org/wiki/Bogot%C3%A1'
    },
    {
      '@type': 'City',
      name: 'Chía',
      sameAs: 'https://es.wikipedia.org/wiki/Ch%C3%ADa'
