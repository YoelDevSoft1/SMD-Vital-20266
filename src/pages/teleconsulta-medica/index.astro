const metadata = {
  title: 'Telemedicina en Bogotá | Teleconsulta Médica Online | SMD Vital',
  description: 'Telemedicina y teleconsulta médica online en Bogotá. Consulta médica virtual por videollamada con médicos certificados. Atención médica online 24/7. Precio $80.000 COP.',
  keywords: 'telemedicina, teleconsulta, teleconsulta médica, consulta médica online, videoconsulta, médico virtual, telemedicina online, atención médica online, médico a domicilio virtual, consulta médica virtual, telemedicina bogotá, médico virtual bogotá',
  ignoreTitleTemplate: true,
  openGraph: {
    siteName: 'SMD Vital Bogotá',
    type: 'website',
    images: [
      {
        url: 'https://images.pexels.com/photos/4225920/pexels-photo-4225920.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1',
        width: 1260,
        height: 750,
      },
    ],
  },
  twitter: {
    handle: '@SMDVitalBogota',
    site: '@SMDVitalBogota',
    cardType: 'summary_large_image',
  },
};

---

<Layout metadata={metadata}>
  <!-- Schema.org JSON-LD -->
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(howToSchema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(reviewSchema)}></script>
  </Fragment>

  <Fragment slot="header">
    <Header
      {...headerData}
      actions={[
        {
          variant: 'secondary',
          text: 'Llamar Ahora',
          href: 'tel:3042912564',
        },
        {
          variant: 'primary',
          text: 'WhatsApp',
          href: 'https://wa.me/573042912564',
          icon: 'tabler:brand-whatsapp',
        },
      ]}
      isSticky
    />
  </Fragment>

  <!-- Hero2 Widget ******************* -->

  <section class="relative -mt-[76px]">
    <!-- Breadcrumbs integrados -->
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 pt-24">
      <Breadcrumbs
        items={[
          { label: 'Servicios', href: '/servicios' },
          { label: 'Teleconsulta Médica' },
        ]}
      />
    </div>
  </section>

  <Hero2
    tagline="Telemedicina y Consulta Médica Virtual"
    actions={[
      { variant: 'primary', target: '_blank', text: 'Telemedicina WhatsApp', href: 'https://wa.me/573042912564' },
      { variant: 'secondary', text: 'Agendar Teleconsulta', href: 'tel:3042912564' },
    ]}
    image={{
      src: 'https://images.pexels.com/photos/4225920/pexels-photo-4225920.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1',
      alt: 'Médico profesional realizando teleconsulta médica a domicilio por videollamada - SMD Vital Bogotá',
      loading: 'eager',
      width: 1260,
      height: 750,
    }}
  >
    <Fragment slot="title">
      <div class="leading-[0.9]">
        <h1 class="text-4xl md:text-6xl font-bold text-gray-900 dark:text-white mb-4">
          Telemedicina en Bogotá
        </h1>
        <div class="text-2xl md:text-3xl text-accent dark:text-white highlight font-semibold">
          Teleconsulta Médica Online
        </div>
        <div class="text-xl md:text-2xl text-gray-700 dark:text-gray-300 mt-2">
          Consulta Médica Virtual
        </div>
      </div>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="font-semibold text-lg">Telemedicina y teleconsulta médica online</span> con médicos certificados para consulta médica virtual, diagnóstico por videollamada y atención médica online en la comodidad de tu hogar.
      <br /><br />
      Nuestro equipo profesional te ofrece telemedicina y consulta médica virtual en las 20 localidades de Bogotá. Precios transparentes sin costos ocultos.
    </Fragment>
  </Hero2>

  <!-- Features Widget *************** -->

  <Features
    id="beneficios"
    tagline="Servicio Profesional"
    title="¿Por qué elegir nuestra telemedicina y teleconsulta médica?"
    subtitle="Ofrecemos telemedicina y consulta médica virtual con médicos certificados y tecnología especializada para brindar el mejor diagnóstico online en la comodidad de tu hogar."
    columns={3}
    items={[
      {
        title: 'Médicos Certificados',
        description: 'Profesionales médicos certificados con amplia experiencia en telemedicina y consulta médica virtual.',
        icon: 'tabler:stethoscope',
      },
      {
        title: 'Tecnología Avanzada',
        description: 'Videollamada HD segura, revisión de exámenes previos y formulación de medicamentos digitales.',
        icon: 'tabler:video',
      },
      {
        title: 'Respuesta en 5 Minutos',
        description: 'Contacto inmediato por WhatsApp o call center. En minutos recibirás confirmación y enlace de conexión.',
        icon: 'tabler:clock',
      },
      {
        title: 'Diagnóstico Inmediato',
        description: 'Consulta virtual con diagnóstico profesional, recomendaciones de tratamiento y prescripciones médicas digitales.',
        icon: 'tabler:microscope',
      },
      {
        title: 'Documentación Legal',
        description: 'Fórmulas médicas, incapacidades y órdenes de laboratorio con validez legal en Colombia.',
        icon: 'tabler:file-description',
      },
      {
        title: 'Cobertura Total',
        description: 'Servicio disponible en las 20 localidades de Bogotá y municipios cercanos. Atención 24/7 todos los días.',
        icon: 'tabler:map-pin',
      },
    ]}
  />

  <!-- Content Widget - Procedimiento **************** -->

  <Content
    id="procedimiento"
    title="¿Cómo Funciona Nuestra Telemedicina y Teleconsulta?"
    subtitle="Proceso profesional paso a paso de telemedicina realizado por médicos certificados con tecnología especializada"
    isReversed
    items={[
      {
        title: '1. Contacto y Triage Digital',
        description:
          'Contactar por WhatsApp o call center, registrar síntomas y antecedentes para asignar al profesional médico adecuado.',
        icon: 'tabler:phone',
      },
      {
        title: '2. Videollamada Segura',
        description: `Recibir enlace de conexión y participar en videollamada HD con el médico especialista desde cualquier dispositivo.`,
        icon: 'tabler:video',
      },
      {
        title: '3. Diagnóstico y Tratamiento',
        description: `Durante la sesión se resuelven dudas, se define medicamentos y plan terapéutico personalizado con documentación completa.`,
        icon: 'tabler:microscope',
      },
      {
        title: '4. Seguimiento y Control',
        description: `Entrega de fórmulas médicas digitales, seguimiento posterior y coordinación de visitas presenciales si es necesario.`,
        icon: 'tabler:file-description',
      },
    ]}
    image={{
      src: 'https://images.pexels.com/photos/4031824/pexels-photo-4031824.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1',
      alt: 'Procedimiento paso a paso de teleconsulta médica profesional por videollamada segura',
      loading: 'lazy',
      width: 1260,
      height: 750,
    }}
  >
    <Fragment slot="content">
      <h2 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Procedimiento Certificado
      </h2>
      <p class="text-muted mt-4">
        Utilizamos plataformas seguras con encriptación de datos y cumplimos con todas las normativas de protección de información médica en Colombia.
      </p>
    </Fragment>
  </Content>

  <!-- Content Widget - Cuándo Necesitas **************** -->

  <Content
    id="cuando-necesitas"
    tagline="Casos Ideales"
    title="¿Cuándo Necesitas Telemedicina y Teleconsulta?"
    subtitle="Identifica cuándo es apropiado realizar telemedicina y consulta médica virtual para resolver tu necesidad de salud."
    items={[
      {
        title: 'Control de Enfermedades Crónicas',
        description: `✓ Hipertensión y diabetes<br>
                      ✓ EPOC y asma<br>
                      ✓ Salud mental<br>
                      ✓ Evaluación de signos vitales<br>
                      ✓ Ajuste de medicamentos`,
        icon: 'tabler:heart-rate-monitor',
      },
      {
        title: 'Urgencias Leves y Pediatría',
        description: `✓ Fiebre y gripas<br>
                      ✓ Alergias y dermatitis<br>
                      ✓ Dolores abdominales<br>
                      ✓ Cuadros respiratorios moderados<br>
                      ✓ Segunda opinión médica`,
        icon: 'tabler:stethoscope',
      },
    ]}
    image={{
      src: 'https://images.pexels.com/photos/7195184/pexels-photo-7195184.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1',
      alt: 'Paciente con síntomas médicos consultando sobre teleconsulta médica profesional a domicilio',
      loading: 'lazy',
      width: 1260,
      height: 750,
    }}
  >
    <Fragment slot="content">
      <h2 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        ¿Cuándo Necesitas Telemedicina y Teleconsulta?
      </h2>
      <p class="text-muted mt-4">
        La telemedicina y teleconsulta médica es ideal para control de enfermedades crónicas, urgencias leves y seguimiento médico regular. 
        Evita desplazamientos innecesarios y recibe atención médica profesional desde la comodidad de tu hogar.
      </p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget - Precios **************** -->

  <Content
    id="precios"
    title="Precios de Telemedicina y Teleconsulta"
    subtitle="Servicio de telemedicina y consulta médica virtual con precios justos y transparentes. Sin sorpresas, sin costos adicionales."
    isReversed
    items={[
      {
        title: 'Precio Fijo Garantizado',
        description: `$80.000 COP - Precio único para todas las localidades de la ciudad. Sin costos ocultos, sin sorpresas.`,
        icon: 'tabler:currency-peso',
      },
      {
        title: 'Todo Incluido',
        description: `Telemedicina y consulta virtual por videollamada, diagnóstico médico profesional, recomendaciones de tratamiento y prescripciones médicas digitales.`,
        icon: 'tabler:checklist',
      },
