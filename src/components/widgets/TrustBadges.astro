---
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';
import Icon from '~/components/ui/Icon.astro';

export interface TrustBadge {
  icon: string;
  title: string;
  description: string;
  accent?: 'blue' | 'green' | 'emerald' | 'purple';
  verified?: boolean;
}

export interface Props {
  badges?: TrustBadge[];
  className?: string;
}

const defaultBadges: TrustBadge[] = [
  {
    icon: 'tabler:shield-check',
    title: 'Certificados por Supersalud',
    description: 'Habilitados oficialmente como prestadores de salud',
    accent: 'blue',
    verified: true,
  },
  {
    icon: 'tabler:stethoscope',
    title: 'Profesionales verificados',
    description: 'Médicos y enfermeras con tarjeta profesional vigente',
    accent: 'emerald',
    verified: true,
  },
  {
    icon: 'tabler:clock-bolt',
    title: 'Respuesta en 45 minutos',
    description: 'Cobertura 24/7 en Bogotá y municipios vecinos',
    accent: 'green',
    verified: true,
  },
  {
    icon: 'tabler:home-heart',
    title: 'Cobertura total Bogotá',
    description: 'Atendemos las 20 localidades y zonas aledañas',
    accent: 'purple',
  },
  {
    icon: 'tabler:lock-shield',
    title: 'Datos protegidos',
    description: 'Protocolos de confidencialidad y habeas data vigentes',
    accent: 'blue',
  },
  {
    icon: 'tabler:star',
    title: '97 % de satisfacción',
    description: 'Evaluación promedio otorgada por pacientes y empresas',
    accent: 'emerald',
  },
];

const accentClasses: Record<string, string> = {
  blue: 'from-sky-500/20 to-sky-500/5 text-sky-700 dark:text-sky-200',
  green: 'from-green-500/20 to-green-500/5 text-green-700 dark:text-green-200',
  emerald: 'from-emerald-500/25 to-emerald-500/5 text-emerald-700 dark:text-emerald-200',
  purple: 'from-violet-500/20 to-violet-500/5 text-violet-700 dark:text-violet-200',
};

const { badges = defaultBadges, className = '' } = Astro.props;

const getAccent = (accent?: string) => accentClasses[accent ?? 'emerald'];
---

<WidgetWrapper
  id="trust-badges"
  containerClass={`max-w-7xl mx-auto ${className}`}
>
  <div class="relative overflow-hidden rounded-3xl bg-white/95 dark:bg-slate-900/70 p-10 shadow-xl">
    <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/10 via-transparent to-sky-500/5 opacity-80"></div>
    <div class="relative">
      <Headline
        title="¿Por qué confiar en SMD Vital?"
        subtitle="Indicadores auditados y certificaciones oficiales respaldan cada visita"
        classes={{
          container: 'text-center mb-12',
          title: 'text-3xl md:text-4xl font-bold text-gray-900 dark:text-white',
          subtitle: 'text-base md:text-lg text-gray-600 dark:text-gray-300',
        }}
      />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {badges.map((badge) => (
          <article class="group relative rounded-2xl border border-white/60 dark:border-white/10 bg-white/90 dark:bg-slate-900/80 p-6 shadow-lg transition duration-300 hover:-translate-y-1 hover:shadow-emerald-500/30">
            <div class={`absolute inset-0 rounded-2xl bg-gradient-to-br ${getAccent(badge.accent)} opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none`}></div>

            <div class="relative flex items-start gap-4">
              <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-500 text-white shadow-emerald-500/40 shadow">
                <Icon name={badge.icon} class="w-6 h-6" />
              </span>

              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2">
                  <h3 class="text-lg font-semibold text-gray-900 dark:text-white">{badge.title}</h3>
                  {badge.verified && (
                    <span class="inline-flex items-center gap-1 rounded-full bg-emerald-100 px-2 py-0.5 text-xs font-semibold text-emerald-600 dark:bg-emerald-900/60 dark:text-emerald-300">
                      <Icon name="tabler:check" class="w-3.5 h-3.5" /> Verificado
                    </span>
                  )}
                </div>
                <p class="mt-2 text-sm leading-relaxed text-gray-600 dark:text-gray-300">
                  {badge.description}
                </p>
              </div>
            </div>
          </article>
        ))}
      </div>

      <div class="mt-12 rounded-2xl border border-white/50 bg-white/80 p-6 text-sm text-gray-600 shadow-sm dark:border-white/10 dark:bg-slate-900/70 dark:text-gray-300">
        <p class="text-center font-semibold uppercase tracking-widest text-emerald-600 dark:text-emerald-300">
          Certificaciones y alianzas de confianza
        </p>
        <div class="mt-5 flex flex-wrap items-center justify-center gap-8 text-gray-500 dark:text-gray-400">
          <span class="flex items-center gap-2">
            <Icon name="tabler:building" class="w-5 h-5" /> Supersalud
          </span>
          <span class="flex items-center gap-2">
            <Icon name="tabler:medal" class="w-5 h-5" /> Ministerio de Salud
          </span>
          <span class="flex items-center gap-2">
            <Icon name="tabler:certificate" class="w-5 h-5" /> Colegio Médico
          </span>
          <span class="flex items-center gap-2">
            <Icon name="tabler:chart-line" class="w-5 h-5" /> Protocolos ISO 9001
          </span>
        </div>
      </div>
    </div>
  </div>
</WidgetWrapper>
