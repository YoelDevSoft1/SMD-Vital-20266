// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User Management
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  phone     String?  @unique
  password  String
  firstName String
  lastName  String
  role      UserRole @default(PATIENT)
  isActive  Boolean  @default(true)
  isVerified Boolean @default(false)
  isPlaceholder Boolean @default(false)
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  patient   Patient?
  doctor    Doctor?
  admin     Admin?
  notifications Notification[]
  encountersAsNurse Encounter[] @relation("EncounterNurse")
  vitalSignsRecorded VitalSign[] @relation("VitalSignRecordedBy")
  serviceTraces ServiceTrace[] @relation("ServiceTraceActor")
  auditLogs AuditLog[] @relation("AuditLogActor")
  assignedAppointments Appointment[] @relation("AppointmentAssignedNurse")
  finishedAppointments Appointment[] @relation("AppointmentFinishedBy")
  medicalRecordsAsNurse MedicalRecord[] @relation("MedicalRecordNurse")

  @@map("users")
}

enum UserRole {
  PATIENT
  DOCTOR
  NURSE
  ADMIN
  SUPER_ADMIN
}

// Patient Information
model Patient {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dateOfBirth DateTime?
  gender      Gender?
  address     String?
  city        String?
  state       String?
  zipCode     String?
  emergencyContact String?
  emergencyPhone   String?
  medicalHistory   String?
  allergies        String?
  medications      String?
  insuranceNumber  String?
  insuranceProvider String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  appointments Appointment[]
  medicalRecords MedicalRecord[]
  prescriptions Prescription[]
  reviews Review[]
  encounters Encounter[]

  @@map("patients")
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

// Doctor Information
model Doctor {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseNumber String   @unique
  specialty     String
  experience    Int      @default(0)
  rating        Float    @default(0)
  totalReviews  Int      @default(0)
  isAvailable   Boolean  @default(true)
  consultationFee Float
  bio           String?
  education     String?
  certifications String?
  languages     String[]
  serviceAreas  String[]
  logoPath      String?
  signaturePath String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  appointments Appointment[]
  reviews      Review[]
  schedules    DoctorSchedule[]
  services     DoctorService[]
  prescriptions Prescription[]
  encounters   Encounter[]
  medicalRecords MedicalRecord[] @relation("MedicalRecordDoctor")

  @@map("doctors")
}

// Admin Information
model Admin {
  id       String   @id @default(cuid())
  userId   String   @unique
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  level    AdminLevel @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

enum AdminLevel {
  ADMIN
  SUPER_ADMIN
}

// Services
model Service {
  id          String   @id @default(cuid())
  name        String
  description String
  category    ServiceCategory
  basePrice   Float
  duration    Int      // in minutes
  isActive    Boolean  @default(true)
  requirements String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  appointments Appointment[]
  doctorServices DoctorService[]

  @@map("services")
}

enum ServiceCategory {
  CONSULTATION
  EMERGENCY
  LABORATORY
  NURSING
  SPECIALIST
  THERAPY
  VACCINATION
  OTHER
}

// Doctor Services (Many-to-Many)
model DoctorService {
  id        String   @id @default(cuid())
  doctorId  String
  serviceId String
  price     Float
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  doctor    Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([doctorId, serviceId])
  @@map("doctor_services")
}

// Appointments
model Appointment {
  id          String   @id @default(cuid())
  patientId   String
  doctorId    String
  serviceId   String
  status      AppointmentStatus @default(PENDING)
  scheduledAt DateTime
  duration    Int      // in minutes
  notes       String?
  diagnosis   String?
  prescription String?
  totalPrice  Float
  address     String
  city        String
  coordinates Json?    // { lat: number, lng: number }
  assignedNurseId String?
  finishedAt  DateTime?
  finishedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  patient     Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor      Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  service     Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  assignedNurse User? @relation("AppointmentAssignedNurse", fields: [assignedNurseId], references: [id], onDelete: SetNull)
  finishedBy  User? @relation("AppointmentFinishedBy", fields: [finishedById], references: [id], onDelete: SetNull)
  encounter   Encounter?
  payments    Payment[]
  reviews     Review[]
  serviceTraces ServiceTrace[]
  medicalRecords MedicalRecord[]
  prescriptions Prescription[]

  @@map("appointments")
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
}

enum EncounterStatus {
  IN_PROGRESS
  COMPLETED
}

enum PrescriptionStatus {
  DRAFT
  FINAL
}

enum ServiceTraceAction {
  STARTED
  UPDATED
  VITALS_RECORDED
  NOTE_ADDED
  PRESCRIPTION_CREATED
  DOCUMENT_SENT
  STATUS_CHANGED
}

enum AuditEntity {
  APPOINTMENT
  ENCOUNTER
  MEDICAL_RECORD
  PRESCRIPTION
  PAYMENT
  USER
  SERVICE
  REVIEW
  NOTIFICATION
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  COMPLETE
  SEND_EMAIL
  LOGIN
  LOGOUT
}

// Clinical Encounter
model Encounter {
  id            String          @id @default(cuid())
  appointmentId String          @unique
  patientId     String
  doctorId      String
  nurseId       String?
  status        EncounterStatus @default(IN_PROGRESS)
  summary       String?
  payload       Json?
  templateVersion String?
  startedAt     DateTime        @default(now())
  finishedAt    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Relations
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patient       Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor        Doctor      @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  nurse         User?       @relation("EncounterNurse", fields: [nurseId], references: [id], onDelete: SetNull)
  vitals        VitalSign[]
  medicalRecords MedicalRecord[]
  prescriptions Prescription[]
  serviceTraces ServiceTrace[]

  @@map("encounters")
}

// Vital Signs
model VitalSign {
  id             String   @id @default(cuid())
  encounterId    String
  recordedById   String
  recordedAt     DateTime @default(now())
  bpSys          Int?
  bpDia          Int?
  heartRate      Int?
  respiratoryRate Int?
  temperature    Float?
  spo2           Int?
  weight         Float?
  height         Float?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  encounter   Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  recordedBy  User      @relation("VitalSignRecordedBy", fields: [recordedById], references: [id], onDelete: Cascade)

  @@map("vital_signs")
}

// Service Traceability
model ServiceTrace {
  id            String            @id @default(cuid())
  appointmentId String
  encounterId   String?
  actorId       String
  actorRole     UserRole
  action        ServiceTraceAction
  payload       Json?
  createdAt     DateTime          @default(now())

  // Relations
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  encounter   Encounter?  @relation(fields: [encounterId], references: [id], onDelete: SetNull)
  actor       User        @relation("ServiceTraceActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@map("service_traces")
}

// Audit Log
model AuditLog {
  id        String      @id @default(cuid())
  actorId   String
  actorRole UserRole
  entity    AuditEntity
  entityId  String
  action    AuditAction
  payload   Json?
  createdAt DateTime    @default(now())

  // Relations
  actor User @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

// Doctor Schedules
model DoctorSchedule {
  id        String   @id @default(cuid())
  doctorId  String
  dayOfWeek Int      // 0 = Sunday, 1 = Monday, etc.
  startTime String   // "09:00"
  endTime   String   // "17:00"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  doctor    Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@map("doctor_schedules")
}

// Payments
model Payment {
  id            String   @id @default(cuid())
  appointmentId String
  amount        Float
  currency      String   @default("COP")
  status        PaymentStatus @default(PENDING)
  method        PaymentMethod
  transactionId String?
  stripePaymentIntentId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@map("payments")
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  NEQUI
  DAVIPLATA
  PSE
}

// Reviews
model Review {
  id           String   @id @default(cuid())
  patientId    String
  doctorId     String
  appointmentId String?
  rating       Int      // 1-5
  comment      String?
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  patient      Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor       Doctor      @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  appointment  Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@map("reviews")
}

// Medical Records
model MedicalRecord {
  id          String   @id @default(cuid())
  patientId   String
  appointmentId String?
  encounterId String?
  doctorId   String?
  nurseId    String?
  title       String
  description String
  type        MedicalRecordType
  fileUrl     String?
  payload     Json?
  pdfPath     String?
  templateVersion String?
  doctorNotes String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  patient     Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  encounter   Encounter? @relation(fields: [encounterId], references: [id], onDelete: SetNull)
  doctor      Doctor? @relation("MedicalRecordDoctor", fields: [doctorId], references: [id], onDelete: SetNull)
  nurse       User? @relation("MedicalRecordNurse", fields: [nurseId], references: [id], onDelete: SetNull)

  @@map("medical_records")
}

enum MedicalRecordType {
  LAB_RESULT
  IMAGING
  PRESCRIPTION
  VACCINATION
  ALLERGY
  DIAGNOSIS
  OTHER
}

// Prescriptions
model Prescription {
  id          String   @id @default(cuid())
  patientId   String
  doctorId    String
  appointmentId String?
  encounterId String?
  medication  String
  dosage      String
  frequency   String
  duration    String
  instructions String?
  status      PrescriptionStatus @default(DRAFT)
  isActive    Boolean  @default(true)
  pdfPath     String?
  templateVersion String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  patient     Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor      Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  encounter   Encounter? @relation(fields: [encounterId], references: [id], onDelete: SetNull)
  items       PrescriptionItem[]

  @@map("prescriptions")
}

// Prescription Items
model PrescriptionItem {
  id             String   @id @default(cuid())
  prescriptionId String
  medication     String
  dosage         String
  frequency      String
  duration       String
  instructions   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@map("prescription_items")
}

// Notifications
model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType
  isRead    Boolean  @default(false)
  data      Json?    // Additional data
  createdAt DateTime @default(now())

  // Relations
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum NotificationType {
  APPOINTMENT_REMINDER
  APPOINTMENT_CONFIRMED
  APPOINTMENT_CANCELLED
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  NEW_MESSAGE
  SYSTEM_UPDATE
  PROMOTION
}

// System Settings
model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  type      SettingType @default(STRING)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

enum SettingType {
  STRING
  NUMBER
  BOOLEAN
  JSON
}

